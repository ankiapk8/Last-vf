# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
# Port for the API server (use 3001 for local dev, 8080 for production)
PORT=3001

# Node environment (development or production)
NODE_ENV=development

# -----------------------------------------------------------------------------
# AI Model Configuration (optional - defaults work well for most use cases)
# -----------------------------------------------------------------------------
# AI_TEXT_MODEL=google/gemini-2.0-flash-001
# AI_VISION_MODEL=google/gemini-2.0-flash-001

# -----------------------------------------------------------------------------
# Frontend Configuration (optional)
# -----------------------------------------------------------------------------
# Port that the frontend proxies API requests to in development
# API_PORT=3001

# -----------------------------------------------------------------------------
# Production Configuration (only needed for production deployment)
# -----------------------------------------------------------------------------
# Path to pre-built frontend files (set automatically in production)
# STATIC_DIR=/app/public

# Base URL path (always / on Render)
# BASE_PATH=/

# -----------------------------------------------------------------------------
# Stripe Configuration (optional - for real payment testing)
# -----------------------------------------------------------------------------
# Get from https://dashboard.stripe.com/test/apikeys
# STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx

# Get from Stripe Dashboard → Products → Your Product → Price ID
# STRIPE_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxx

# Get from Stripe CLI after running: stripe listen --forward-to localhost:3001/api/stripe/webhook
# STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx