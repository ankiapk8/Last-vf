# ── AI provider (required) ──────────────────────────────────────────────────────
# Get a free key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-your-key-here

# OpenRouter is OpenAI-compatible — keep this URL as-is.
AI_INTEGRATIONS_OPENAI_BASE_URL=https://openrouter.ai/api/v1

# Optional: override which AI models are used (defaults shown)
# AI_TEXT_MODEL=google/gemini-2.0-flash-001
# AI_VISION_MODEL=google/gemini-2.0-flash-001

# ── Database ────────────────────────────────────────────────────────────────────
# Local dev: start Postgres with `docker compose up db` then use this URL.
# Render.com: set automatically from the linked database (see render.yaml).
DATABASE_URL=postgres://ankigen:ankigen@localhost:5432/ankigen

# ── API server ─────────────────────────────────────────────────────────────────
# Port the Express API server listens on locally.
PORT=3001

# ── Frontend (Vite) ────────────────────────────────────────────────────────────
# The Vite dev server proxies /api → http://localhost:API_PORT automatically.
# Set API_PORT if you changed PORT above.
# API_PORT=3001

# ── Production / Docker ────────────────────────────────────────────────────────
# These are set automatically by docker-compose and render.yaml — do not set
# them for local dev unless you are running the production build locally.
# NODE_ENV=production
# STATIC_DIR=/app/public
# BASE_PATH=/
